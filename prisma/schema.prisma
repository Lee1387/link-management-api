generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Link {
  id          String   @id @default(cuid())
  originalUrl String   @db.Text
  shortCode   String   @unique @db.VarChar(32)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
